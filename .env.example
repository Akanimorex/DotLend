# ── Deployment ──────────────────────────────────────────────────────────────────
# Private key of the deployer wallet (no 0x prefix needed for some tools; add it if required)
PRIVATE_KEY=your_private_key_here

# RPC endpoint for Polkadot Hub EVM (Westend Asset Hub testnet default shown)
RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io

# ── Existing token addresses (optional) ─────────────────────────────────────────
# If left empty, the deploy script will deploy mock versions automatically.

# WDOT ERC-20 address on the target network
WDOT_ADDRESS=

# USDC (or other stablecoin) ERC-20 address on the target network
USDC_ADDRESS=

# Price oracle address (must implement IPriceOracle)
ORACLE_ADDRESS=

# ── Verification (optional) ──────────────────────────────────────────────────────
# API key for block-explorer contract verification (e.g. Blockscout)
ETHERSCAN_API_KEY=
